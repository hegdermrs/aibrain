# Brain — Operations Co-Founder
# Environment configuration (copy to .env and fill in)

# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use
BRAIN_MODEL=claude-sonnet-5

# Data directory for transcripts, briefings, analysis output
BRAIN_DATA_DIR=./data

# ── Hermes interface (data ingestion only) ──
# Hermes drops its digest files here
HERMES_DIGEST_DIR=./data/incoming
HERMES_TRANSCRIPT_DIR=./data/transcripts

# ── Phase 2: automation server ──
# Where Brain drops delivery-ready results for Hermes to pull
BRAIN_OUTGOING_DIR=./data/outgoing

# Scheduled briefings (UTC hours). Defaults: 12:00 UTC (~7am ET), 23:00 UTC (~6pm ET)
BRAIN_ENABLE_SCHEDULER=true
BRIEFING_MORNING_HOUR_UTC=12
BRIEFING_EVENING_HOUR_UTC=23
