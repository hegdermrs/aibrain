# Brain — Operations Co-Founder
# Environment configuration (copy to .env and fill in)

# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use
BRAIN_MODEL=claude-sonnet-5

# Data directory for transcripts, briefings, analysis output
BRAIN_DATA_DIR=./data

# ── Hermes interface (data ingestion only) ──
# Hermes drops its digest files here
HERMES_DIGEST_DIR=./data/incoming
HERMES_TRANSCRIPT_DIR=./data/transcripts

# ── Telegram (direct delivery to Jim) ──
# From @BotFather. Jim's chat id is learned when he taps Start on the bot.
# If set, the Brain texts Jim directly (no Hermes delivery hop).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email polling (24/7 Fathom-call ingestion, no Mac/Zapier) ──
# Reads the inbox on an interval for Fathom call emails, analyzes, delivers.
# Gmail: enable 2FA, then create an App Password and use it below.
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_ADDRESS=
EMAIL_APP_PASSWORD=
FATHOM_FROM=fathom
EMAIL_POLL_MINUTES=15

# ── Phase 2: automation server ──
# Fallback outbox: if Telegram is unset, results wait here for a puller
BRAIN_OUTGOING_DIR=./data/outgoing

# Scheduled briefings (UTC hours). Defaults: 12:00 UTC (~7am ET), 23:00 UTC (~6pm ET)
BRAIN_ENABLE_SCHEDULER=true
BRIEFING_MORNING_HOUR_UTC=12
BRIEFING_EVENING_HOUR_UTC=23
